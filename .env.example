PORT=4173
DATA_DIR=/var/data
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_REVENUE_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_INVOICE_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Link da view filtrada no Notion para compras necessarias/lista de solicitacoes.
NOTION_PURCHASES_VIEW_URL=https://www.notion.so/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx?v=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Links opcionais para o painel "Notion Gestao" no app do gestor.
NOTION_MANAGEMENT_DASHBOARD_URL=https://app.notion.com/p/Dashboard-Gest-o-397643c289174f3886e28b17f737329d?source=copy_link
NOTION_MANAGEMENT_STOCK_URL=
NOTION_MANAGEMENT_REVENUE_URL=
NOTION_MANAGEMENT_INVOICES_URL=
NOTION_MANAGEMENT_USERS_URL=
NOTION_MANAGEMENT_TIME_CLOCK_URL=
NOTION_MANAGEMENT_ACTIVITIES_URL=
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Opcional. Se deixar vazio/remover, o app usa o modelo padrao e tenta alternativas.
OPENAI_VISION_MODEL=gpt-5-mini
APP_USERS=extra:1234:Funcionario Extra

# Sistema de ponto por geolocalização.
# Use a latitude/longitude da loja e um raio permitido em metros.
STORE_LATITUDE=
STORE_LONGITUDE=
STORE_RADIUS_METERS=80
STORE_MAX_ACCURACY_METERS=120

# Estes nomes devem coincidir com as propriedades da database do Notion.
NOTION_PROPERTY_PRODUCT=Produto
